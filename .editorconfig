root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4
max_line_length = 100

[*.{ts,js,json}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{toml,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
